rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PHASE 3: Primitives ---
    function isSignedIn() { 
      return request.auth != null && request.auth.token.email_verified == true; 
    }
    
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isRole(roleStr) {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == roleStr;
    }

    function isAdmin() {
      return isSignedIn() && isRole('ADMIN');
    }

    // --- Bootstrapped connection check ---
    match /test/connection {
      allow read: if true; // Publicly readable for boot check
    }

    // --- PHASE 4: Fortress Rules ---

    // 1. USERS
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['id', 'name', 'email', 'role'])
          && data.size() >= 4 && data.size() <= 15
          && data.id is string && data.id.size() > 0 && data.id.size() <= 128
          && data.name is string && data.name.size() > 0 && data.name.size() <= 150
          && data.email is string && data.email.size() > 0 && data.email.size() <= 150
          && data.role is string && data.role in ['ADMIN', 'AGENT', 'TENANT']
          && (!('phone' in data) || (data.phone is string && data.phone.size() <= 30))
          && (!('walletBalance' in data) || (data.walletBalance is number))
          && (!('assignedPropertyIds' in data) || (data.assignedPropertyIds is list && data.assignedPropertyIds.size() <= 100));
      }

      allow create: if isSignedIn() 
                    && isValidId(userId)
                    && isValidUser(incoming())
                    && incoming().id == userId
                    && userId == request.auth.uid;

      allow get: if isSignedIn() && (request.auth.uid == userId || isRole('AGENT') || isAdmin());
      
      allow list: if isSignedIn() && (
        resource.data.id == request.auth.uid 
        || isRole('AGENT') 
        || isAdmin()
      );

      allow update: if isSignedIn() 
                    && isValidUser(incoming())
                    && incoming().id == existing().id // Entity remains same
                    && incoming().role == existing().role // Role is immutable
                    && incoming().email == existing().email // Email is immutable
                    && (
                      isAdmin() ||
                      // Action: User update profile
                      (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'profilePictureUrl'])) ||
                      // Action: Agent or internal system update balance/assignments
                      (isRole('AGENT') && incoming().diff(existing()).affectedKeys().hasOnly(['assignedPropertyIds', 'walletBalance']))
                    );
    }

    // 2. PROPERTIES
    match /properties/{propertyId} {
      function isValidProperty(data) {
        return data.keys().hasAll(['id', 'name', 'location', 'rent', 'status', 'agentId', 'category', 'type'])
          && data.size() >= 8 && data.size() <= 20
          && data.id is string && data.id.size() <= 128
          && data.name is string && data.name.size() <= 200
          && data.location is string && data.location.size() <= 300
          && data.rent is number && data.rent >= 0
          && data.status is string && data.status in ['DRAFT', 'LISTED', 'OCCUPIED', 'VACANT', 'ARCHIVED']
          && data.agentId is string && data.agentId.size() <= 128
          && data.category is string && data.category.size() <= 100
          && data.type is string && data.type.size() <= 100
          && (!('images' in data) || (data.images is list && data.images.size() <= 20));
      }

      allow read: if isSignedIn();
      
      allow create: if isSignedIn() 
                    && (isRole('AGENT') || isAdmin())
                    && isValidId(propertyId)
                    && isValidProperty(incoming())
                    && incoming().id == propertyId
                    && incoming().agentId == request.auth.uid;

      allow update: if isSignedIn()
                    && isValidProperty(incoming())
                    && (
                      isAdmin() ||
                      (existing().agentId == request.auth.uid && incoming().agentId == existing().agentId && incoming().id == existing().id && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'location', 'rent', 'status', 'description', 'category', 'type', 'images', 'tenantId', 'rentStartDate', 'rentExpiryDate']))
                    );

      allow delete: if isSignedIn() && (existing().agentId == request.auth.uid || isAdmin());
    }

    // 3. APPLICATIONS
    match /applications/{applicationId} {
      function isValidApplication(data) {
        return data.keys().hasAll(['id', 'userId', 'propertyId', 'agentId', 'status', 'submissionDate', 'firstName', 'surname'])
          && data.size() >= 8 && data.size() <= 80
          && data.id is string && data.id.size() <= 128
          && data.userId is string && data.userId.size() <= 128
          && data.propertyId is string && data.propertyId.size() <= 128
          && data.agentId is string && data.agentId.size() <= 128
          && data.status is string && data.status in ['PENDING', 'REVIEWING', 'APPROVED', 'REJECTED', 'MORE_INFO_REQUIRED']
          && data.submissionDate is string && data.submissionDate.size() <= 100;
      }

      allow create: if isSignedIn()
                    && isValidId(applicationId)
                    && isValidApplication(incoming())
                    && incoming().id == applicationId
                    && incoming().userId == request.auth.uid
                    && incoming().status == 'PENDING'
                    && exists(/databases/$(database)/documents/properties/$(incoming().propertyId));

      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.agentId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.agentId == request.auth.uid || isAdmin());

      allow update: if isSignedIn()
                    && isValidApplication(incoming())
                    && incoming().id == existing().id
                    && incoming().userId == existing().userId
                    && incoming().propertyId == existing().propertyId
                    && (
                      isAdmin() ||
                      // Action: Agent review
                      (request.auth.uid == existing().agentId && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'riskScore', 'aiRecommendation'])) ||
                      // Action: Tenant edit
                      (request.auth.uid == existing().userId && (existing().status == 'PENDING' || existing().status == 'MORE_INFO_REQUIRED'))
                    );
    }

    // 4. AGREEMENTS
    match /agreements/{agreementId} {
      function isValidAgreement(data) {
        return data.keys().hasAll(['id', 'propertyId', 'tenantId', 'startDate', 'endDate', 'status', 'version'])
          && data.size() >= 6 && data.size() <= 12
          && data.id is string && data.id.size() <= 128
          && data.propertyId is string && data.propertyId.size() <= 128
          && data.tenantId is string && data.tenantId.size() <= 128;
      }

      // Secure Read: only participants can see the agreement
      allow read: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid 
        || get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.agentId == request.auth.uid
        || isAdmin()
      );
      
      allow create: if isSignedIn() 
                    && isValidAgreement(incoming())
                    && (isAdmin() || get(/databases/$(database)/documents/properties/$(incoming().propertyId)).data.agentId == request.auth.uid);
    }

    // 5. MAINTENANCE TICKETS
    match /tickets/{ticketId} {
      function isValidTicket(data) {
        return data.keys().hasAll(['id', 'tenantId', 'propertyId', 'issue', 'status', 'priority', 'createdAt'])
          && data.size() >= 7 && data.size() <= 15
          && data.id is string && data.id.size() <= 128
          && data.status is string && data.status in ['OPEN', 'IN_PROGRESS', 'RESOLVED']
          && data.priority is string && data.priority in ['LOW', 'MEDIUM', 'HIGH', 'EMERGENCY'];
      }

      allow read: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid 
        || get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.agentId == request.auth.uid
        || isAdmin()
      );
      
      allow create: if isSignedIn() 
                    && isValidTicket(incoming())
                    && incoming().id == ticketId
                    && incoming().tenantId == request.auth.uid
                    && exists(/databases/$(database)/documents/properties/$(incoming().propertyId));

      allow update: if isSignedIn()
                    && isValidTicket(incoming())
                    && incoming().id == existing().id
                    && incoming().tenantId == existing().tenantId
                    && incoming().propertyId == existing().propertyId
                    && (
                      isAdmin() ||
                      // Action: Tenant edit description
                      (request.auth.uid == existing().tenantId && incoming().diff(existing()).affectedKeys().hasOnly(['issue', 'imageUrl'])) ||
                      // Action: Agent update status/priority
                      (request.auth.uid == get(/databases/$(database)/documents/properties/$(existing().propertyId)).data.agentId && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'priority', 'aiAssessment']))
                    );
    }

    // 6. PAYMENTS & TRANSACTIONS
    match /payments/{paymentId} {
      allow read: if isSignedIn() && (resource.data.tenantId == request.auth.uid || isRole('AGENT') || isAdmin());
    }

    match /transactions/{transactionId} {
       function isValidTransaction(data) {
        return data.keys().hasAll(['id', 'userId', 'amount', 'type', 'purpose', 'timestamp', 'status'])
          && data.size() == 7
          && data.id is string && data.id.size() <= 128
          && data.userId is string && data.userId.size() <= 128;
      }
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidTransaction(incoming()) && (incoming().userId == request.auth.uid || isAdmin());
    }

    // 7. NOTIFICATIONS
    match /notifications/{notificationId} {
      function isValidNotification(data) {
        return data.keys().hasAll(['id', 'userId', 'title', 'message', 'type', 'timestamp', 'isRead'])
          && data.size() >= 7 && data.size() <= 12;
      }
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidNotification(incoming()); 
    }

    // 8. FORM TEMPLATES
    match /formTemplates/{templateId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (request.auth.uid == templateId || isAdmin());
    }

  }
}
